  | $def.14
def fact.2($def.24)
  cocase
    .ap($p1.26; $lambda.25) ->
      μ $case.27:
        μ $ap.28:
          :tuple
          | .ap($p1.26; $ap.28)
        | case
            :tuple.ap(0; $_.29) ->
              1
              | $case.27
            :tuple.ap(n.30; $_.31) ->
              μ $ap.33:
                μ $top.32:
                  invoke mul.0($top.32)
                | .ap(
                    n.30,
                    μ $ap.35:
                      μ $top.34:
                        invoke fact.2($top.34)
                      | .ap(
                          μ $ap.37:
                            μ $top.36:
                              invoke sub.1($top.36)
                            | .ap(n.30, 1; $ap.37); 
                          $ap.35); 
                    $ap.33)
              | $case.27
      | $lambda.25
  | $def.24
def main.3($def.38)
  cocase
    .ap(; $lambda.39) ->
      μ $prim.40:
        prim print_trace(
          μ $ap.42:
            μ $top.41:
