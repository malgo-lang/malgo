def mul.0($def.4)
  cocase
    .ap($p1.6, $p2.7; $lambda.5) ->
      μ $case.8:
        μ $ap.9:
          :tuple
          | .ap($p1.6, $p2.7; $ap.9)
        | case
            :tuple.ap(x.10, y.11; $_.12) ->
              μ $prim.13:
                prim mul(x.10, y.11; $prim.13)
              | $case.8
      | $lambda.5
  | $def.4
def sub.1($def.14)
  cocase
    .ap($p1.16, $p2.17; $lambda.15) ->
      μ $case.18:
        μ $ap.19:
          :tuple
          | .ap($p1.16, $p2.17; $ap.19)
        | case
            :tuple.ap(x.20, y.21; $_.22) ->
